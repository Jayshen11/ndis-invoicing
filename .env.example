# Local PostgreSQL settings for Docker and Next.js.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=ndis_db

# Optional: use a fully managed connection string instead of the individual values above.
# DATABASE_URL=

# Optional: server automation only — Bearer skips per-permission checks when there is NO session cookie.
# Do not forward this header to browser traffic (proxies); signed-in users always use session RBAC.
# INTERNAL_API_TOKEN=

# --- AI PDF invoice import (PoC) ---
# Required for POST /api/invoices/extract-pdf (except local stub testing without key is not supported — returns 503).
OPENAI_API_KEY=
# Optional: default https://api.openai.com/v1
# OPENAI_BASE_URL=
# Optional: default gpt-4o-mini
# OPENAI_MODEL=

# Optional: store uploaded PDFs in S3 and pass a time-limited signed URL to the model prompt.
# When unset, extraction still runs from in-memory PDF text only.
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
